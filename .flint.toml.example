[provider]
type = "openai"
model = "gpt-4o"

[agent]
max_turns = 50
max_output_chars = 65536

[session]
persistence = true
# path = '/path/to/.flint/sessions'

[logging]
level = "warn"

[features.skills]
enabled = true

[features.memory]
enabled = true
# max_core_blocks = 8       # max always-in-context memory blocks
# max_block_chars = 2000    # char limit per core block
# auto_extract = true       # auto-extract facts after each turn
# search_limit = 5          # max memories to inject per turn

[features.compaction]
enabled = true

[features.permissions]
enabled = true

# MCP servers — external tool servers via Model Context Protocol
# [mcp_servers.memory]
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-memory"]
#
# [mcp_servers.filesystem]
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/dir"]
